# Split staging / production — copy values to your CI secrets or host env.
# Do not commit real secrets. See docs/SPLIT_DEPLOYMENT_AND_MIGRATION.md and docs/HOSTING_DECISIONS.md.

# --- Build machine (or CI "build frontend" job) ---
# Public API origin, no trailing slash. Baked into dist/ at build time.
# VITE_API_BASE=https://api.staging.example.com

# --- API process environment ---
# NODE_ENV=production
# PORT=8787

# Exact UI origin(s) the browser will use (comma-separated). Must match HOSTING_DECISIONS.md.
# CORS_ORIGIN=https://app.staging.example.com

# strict | lax | none — use none only when UI and API are different *sites* (unrelated domains).
# ZAREWA_COOKIE_SAMESITE=strict
# Optional for sibling subdomains (app.example.com + api.example.com): .example.com
# ZAREWA_COOKIE_DOMAIN=.example.com

# COOKIE_SECURE=1

# Persistent SQLite path on the API host.
# ZAREWA_DB=/var/lib/zarewa/staging.sqlite

# Optional: do not set ZAREWA_STATIC_DIR when UI is hosted separately (API should not serve dist/).
