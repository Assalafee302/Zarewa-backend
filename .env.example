# Copy to `.env` / `.env.local` / platform env as needed. See docs/ENVIRONMENT.md
# and docs/SPLIT_DEPLOYMENT_AND_MIGRATION.md.
# Split staging / prod pairs: see .env.split-staging.example and docs/HOSTING_DECISIONS.md.

# --- Frontend (Vite; only vars prefixed VITE_ are exposed to the client) ---
# Empty: use same-origin `/api` (Vite dev proxy or API serving dist/).
# Set for split deploy: full HTTPS origin, no trailing slash.
# VITE_API_BASE=https://api.example.com

NODE_ENV=production
CORS_ORIGIN=https://your-frontend-url.vercel.app
ZAREWA_COOKIE_SAMESITE=none
COOKIE_SECURE=1
ZAREWA_DB=/data/zarewa.sqlite
ZAREWA_STATIC_DIR=/app/dist

# --- Firebase Admin (Google sign-in → same cookie session as password login) ---
FIREBASE_PROJECT_ID="zarewa-63333"
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/serviceAccount.json
GOOGLE_APPLICATION_CREDENTIALS= C:\zarewa project\zarewa v3\backend\secrets\zarewa-63333-firebase-adminsdk-fbsvc-a9e150d24d.json
# Zarewa maps Firebase users by verified email: set app_users.email to the same address as the Google account.
