{
  "name": "@zarewa/backend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev:stack": "node scripts/dev-stack.mjs",
    "server": "node server/index.js",
    "start": "node server/index.js",
    "start:lan": "node scripts/start-lan.mjs",
    "db:migrate": "node scripts/db-migrate.mjs",
    "db:wipe": "node scripts/wipe-local-mysql.mjs",
    "wipe:e2e-db": "node scripts/wipe-playwright-e2e.mjs",
    "db:wipe-empty-client": "node scripts/wipe-empty-client.mjs",
    "db:legacy-demo": "node server/applyLegacyDemoPackCli.js",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:sales-refund-finance": "playwright test e2e/sales-refund-finance-checklist.spec.js",
    "test:e2e:refund-risk": "playwright test e2e/refund-risk-api.spec.js",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run test && npm run test:e2e",
    "test:transactions": "vitest run server/scenarioMatrix.test.js server/transactionalScenarios.test.js",
    "test:operations": "vitest run server/inventoryScenarios.test.js server/accessoryFulfillment.test.js server/transactionalScenarios.test.js",
    "test:financial": "vitest run server/refundSecurity.test.js server/refundE2E.test.js server/accountingPhase2.test.js server/accountingStatementsOps.test.js server/api.test.js",
    "test:critical-workflows": "vitest run server/ensureLegacyDemoPack.test.js server/refundSecurity.test.js server/refundE2E.test.js server/accountingPhase2.test.js server/api.test.js",
    "test:ops-finance": "npm run test:operations && npm run test:financial",
    "test:e2e:operations": "playwright test e2e/complete-gate.spec.js --grep \"operations: Store\"",
    "test:e2e:production": "playwright test e2e/complete-gate.spec.js e2e/production-register.spec.js --grep \"Store & production|Production register\"",
    "test:e2e:finance": "playwright test e2e/complete-gate.spec.js --grep \"finance manager\"",
    "test:e2e:ops-finance": "playwright test e2e/complete-gate.spec.js --grep \"finance manager|operations: Store\"",
    "verify:ci": "npm run lint && npm run test:transactions",
    "verify:split-deploy": "node scripts/verify-split-deploy.mjs",
    "verify:complete": "node scripts/verify-complete.mjs",
    "hr:import-staff": "node server/importZarewaStaffFromXlsx.js",
    "import:access-sales": "node server/importAccessSalesPack.mjs",
    "import:access-staging": "node scripts/staging-import-access.mjs",
    "import:validate": "node scripts/validate-access-import.mjs",
    "import:merge-report": "node server/importAccessSalesPack.mjs --customer-merge-report",
    "import:legacy-branch": "node scripts/reassign-legacy-import-branch.mjs",
    "import:legacy-treasury": "node scripts/backfill-legacy-receipt-treasury.mjs",
    "import:access-finance": "node server/importAccessFinancePack.mjs",
    "stress:api": "node scripts/stress-api.mjs",
    "stress:lifecycle": "node scripts/fifty-lifecycle-stress.mjs",
    "stress:qa-mega": "node scripts/qa-operations-mega.mjs",
    "stress:qa-mega-lite": "node scripts/qa-mega-lite.mjs",
    "stress:finance100": "node scripts/finance-stress-100.mjs",
    "bench:dashboard": "node scripts/bench-dashboard-summary.mjs",
    "retention:prune": "node scripts/retention-prune.mjs",
    "build": "node -e \"console.log('[zarewa] build: no compile step (API-only package)');\"",
    "serve:built:lan": "node scripts/serve-built-lan.mjs",
    "install:ci": "npm ci"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "firebase-admin": "^13.0.0",
    "mysql2": "^3.22.1",
    "synckit": "^0.11.12",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "eslint": "^9.39.4",
    "globals": "^17.4.0",
    "supertest": "^7.2.2",
    "vitest": "3.2.4"
  }
}
